# ------------------------------------------------------------------
# VietConnect Egy — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ------------------------------------------------------------------

# Database (PostgreSQL)
DATABASE_URL="postgresql://vietconnect:vietconnect@localhost:5432/vietconnect_egy?schema=public"

# Auth.js
AUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP / Email (use Mailtrap or similar in development)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="VietConnect Egy <no-reply@vietconnect-egy.local>"

# AI Assistant Provider: "mock" | "openai" | "anthropic" | "gemini"
AI_PROVIDER="mock"
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# File Storage (used only if S3_BUCKET is set; otherwise local /public/uploads is used)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Public
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_MAP_PROVIDER="osm"
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
